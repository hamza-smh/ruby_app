<p style="color: green"><%= notice %></p>

<% content_for :title, "Articles" %>

<h1>Articles</h1>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Descriptions</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @articles.each do |article| %>
      <tr>
        <td><%= article.title =%></td>
        <td><%= article.description =%></td>
        <td> Actions </td>
      </tr>
    <% end %>
  </tbody>

</table>

<%= link_to "New article", new_article_path %>
